{
  "id": "molecule_viever",
  "type": "SharedSlice",
  "name": "MoleculeViever",
  "description": "MoleculeViever",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "visible": {
          "type": "Boolean",
          "config": {
            "label": "Visible",
            "placeholder_false": "false",
            "placeholder_true": "true",
            "default_value": true
          }
        },
        "model_file": {
          "type": "Link",
          "config": {
            "label": "3D Model File",
            "placeholder": "Upload a .glb or .gltf file",
            "select": "media"
          }
        },
        "dev_mode": {
          "type": "Boolean",
          "config": {
            "label": "Developer Mode",
            "placeholder_false": "false",
            "placeholder_true": "true",
            "default_value": false
          }
        },
        "settings_json": {
          "type": "Text",
          "config": {
            "label": "Settings JSON (paste from Dev Mode)",
            "placeholder": "{}"
          }
        }
      },
      "items": {
        "mesh_name": {
          "type": "Text",
          "config": {
            "label": "Mesh Name",
            "placeholder": "e.g. antibodyActiveLighter"
          }
        },
        "mesh_color": {
          "type": "Color",
          "config": {
            "label": "Mesh Color"
          }
        },
        "info_title": {
          "type": "Text",
          "config": {
            "label": "Info Title",
            "placeholder": "Title shown in the popup"
          }
        },
        "info_text": {
          "type": "StructuredText",
          "config": {
            "label": "Info Text",
            "placeholder": "Description shown when this mesh is clicked",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em"
          }
        }
      }
    }
